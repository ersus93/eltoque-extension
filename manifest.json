{
  "manifest_version": 3,
  "name": "BitBread Alerts - Tasas ElToque \u2014 Mercado Informal Cuba",
  "short_name": "BBAlert - Tasas ElToque",
  "version": "1.4.0",
  "description": "Tasas del mercado informal cubano. Escribe 'et' en la barra de direcciones para consultar.",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "src/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "BitBread Alerts \u2014 ElToque - Tasas de Cambio"
  },
  "background": {
    "service_worker": "src/background.js"
  },
  "options_ui": {
    "page": "src/options.html",
    "open_in_tab": true
  },
  "omnibox": {
    "keyword": "et"
  },
  "chrome_url_overrides": {
    "newtab": "src/newtab.html"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "src/content.js"
      ],
      "css": [
        "src/content.css"
      ],
      "run_at": "document_end"
    }
  ],
  "permissions": [
    "storage",
    "alarms",
    "scripting",
    "notifications",
    "tabs"
  ],
  "host_permissions": [
    "https://tasas.eltoque.com/*",
    "https://api.binance.com/*",
    "https://api.binance.us/*",
    "https://api1.binance.com/*",
    "https://api2.binance.com/*",
    "https://api3.binance.com/*"
  ]
}